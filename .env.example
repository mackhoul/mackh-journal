# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Supabase Service Role key (Settings → API → service_role)
# WARNING: this is a secret key — never expose it in frontend code
SUPABASE_SERVICE_ROLE_KEY=

# Port (Render sets this automatically — do not set it manually on Render)
# PORT=3000
